# Backend (required)
OPENROUTER_API_KEY=your_openrouter_api_key

# Backend (optional — choose model, default: anthropic/claude-sonnet-4-5)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Backend (optional — for ElevenLabs voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Backend (optional — Vercel frontend URL for CORS, set this on Render)
# FRONTEND_URL=https://your-app.vercel.app

# Frontend (optional — Render backend URL, set this on Vercel)
# VITE_API_URL=https://manik-ai-backend.onrender.com
