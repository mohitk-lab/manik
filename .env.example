# ═══════════════════════════════════════════════════
# MANIK.AI v2 — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── AI Model (required) ────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key

# ── Smart Switching Model Tiers (optional) ─────────
# Set SMART_ROUTING=false to always use STANDARD model
SMART_ROUTING=true
MODEL_MINI=anthropic/claude-haiku-3-5
MODEL_STANDARD=anthropic/claude-sonnet-4-5
MODEL_POWER=anthropic/claude-opus-4-6

# ── Voice Generation (optional) ────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ── Telegram Bot (optional) ────────────────────────
# 1. Message @BotFather on Telegram
# 2. /newbot → get token
# TELEGRAM_BOT_TOKEN=123456789:AABBccdd...

# ── WhatsApp Cloud API (optional) ──────────────────
# 1. developers.facebook.com → Create App → WhatsApp
# 2. Get Phone Number ID + permanent access token
# 3. Set webhook: https://your-domain/api/whatsapp/webhook
# WHATSAPP_PHONE_NUMBER_ID=1234567890
# WHATSAPP_ACCESS_TOKEN=EAAxxxx...
# WHATSAPP_VERIFY_TOKEN=manik-ai-verify   ← any secret string

# ── Google Calendar + Gmail (optional) ─────────────
# 1. console.cloud.google.com → Enable Calendar API + Gmail API
# 2. Create OAuth2 credentials → download credentials.json
# 3. Run: cd backend && python setup_google.py
# 4. Paste the resulting token.json contents below (as one line)
# GOOGLE_TOKEN_JSON={"token":"ya29.xxx","refresh_token":"1//xxx",...}
# GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"xxx",...}}

# ── Production Deploy ───────────────────────────────
# Backend on Render: set FRONTEND_URL to your Vercel URL
# FRONTEND_URL=https://your-app.vercel.app

# Frontend on Vercel: set VITE_API_URL to your Render URL
# VITE_API_URL=https://manik-ai-backend.onrender.com
